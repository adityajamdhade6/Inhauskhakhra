<!doctype html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <title>{{ shop.name }}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Anton&family=Space+Grotesk:wght@400;500;700&display=swap" rel="stylesheet">
  {{ content_for_header }}
  {{ 'theme.css' | asset_url | stylesheet_tag }}
</head>
<body>
  <section style="min-height:100vh;display:flex;flex-direction:column;align-items:center;justify-content:center;background:var(--color-masala);text-align:center;padding:40px;">
    <h1 class="ihk-display" style="color:var(--color-cream);font-size:clamp(48px, 10vw, 130px);">
      {{ shop.name | default: 'INHAUS KHAKHRA' | upcase }}
    </h1>
    <p style="margin-top:16px;font-size:18px;font-weight:500;color:rgba(251,241,224,0.9);">Something crunchy is coming.</p>

    {{ content_for_layout }}
  </section>
</body>
</html>
