{%- comment -%}
  Usage: {% render 'floating-piece', size: 48, variant: 'pair', rotate: -12, position: 'top:26%;left:6%;', slow: false, delay: 0.2, hide_mobile: true %}
{%- endcomment -%}
{%- assign size = size | default: 48 -%}
{%- assign variant = variant | default: 'pair' -%}
{%- assign rotate = rotate | default: 0 -%}
{%- assign position = position | default: '' -%}
{%- assign delay = delay | default: 0 -%}

{%- if variant == 'bite' -%}
  {%- assign img = 'khakhra-bite.png' -%}
  {%- assign ratio = 0.7714 -%}
{%- else -%}
  {%- assign img = 'khakhra-pair.png' -%}
  {%- assign ratio = 0.7816 -%}
{%- endif -%}
{%- assign h = size | divided_by: ratio -%}

<div
  class="ihk-floating{% if slow %} ihk-floating--slow{% endif %}{% if hide_mobile %} ihk-hide-mobile{% endif %}"
  style="{{ position }}width:{{ size }}px;height:{{ h }}px;--float-rot:{{ rotate }}deg;transform:rotate({{ rotate }}deg);animation-delay:{{ delay }}s;"
  aria-hidden="true"
>
  <img
    src="{{ img | asset_url }}"
    alt=""
    width="{{ size }}"
    loading="lazy"
    style="width:100%;height:100%;filter:drop-shadow(4px 6px 8px rgba(25,17,8,0.25));"
  >
</div>
