{%- comment -%}
  Usage: {% render 'social-icons', color: 'var(--color-cream)', size: 20 %}
  Renders only the platforms that have a URL set in Theme Settings.
{%- endcomment -%}
{%- assign color = color | default: 'currentColor' -%}
{%- assign size = size | default: 20 -%}

<div style="display:flex;align-items:center;gap:16px;color:{{ color }};">
  {%- if settings.instagram_url != blank -%}
    <a href="{{ settings.instagram_url }}" aria-label="Instagram" target="_blank" rel="noopener">
      <svg width="{{ size }}" height="{{ size }}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <rect x="2" y="2" width="20" height="20" rx="5" />
        <circle cx="12" cy="12" r="4.2" />
        <circle cx="17.4" cy="6.6" r="1" fill="currentColor" stroke="none" />
      </svg>
    </a>
  {%- endif -%}
  {%- if settings.facebook_url != blank -%}
    <a href="{{ settings.facebook_url }}" aria-label="Facebook" target="_blank" rel="noopener">
      <svg width="{{ size }}" height="{{ size }}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M15 8h2V4h-2c-2.2 0-4 1.8-4 4v2H9v4h2v6h4v-6h2.5l.5-4H15V8Z" stroke-linejoin="round" />
      </svg>
    </a>
  {%- endif -%}
  {%- if settings.tiktok_url != blank -%}
    <a href="{{ settings.tiktok_url }}" aria-label="TikTok" target="_blank" rel="noopener">
      <svg width="{{ size }}" height="{{ size }}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M14 3v11.5a3.5 3.5 0 1 1-3.5-3.5" stroke-linecap="round" />
        <path d="M14 3c0 2.8 2.2 5 5 5" stroke-linecap="round" />
      </svg>
    </a>
  {%- endif -%}
  {%- if settings.x_url != blank -%}
    <a href="{{ settings.x_url }}" aria-label="X (Twitter)" target="_blank" rel="noopener">
      <svg width="{{ size }}" height="{{ size }}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M4 4l16 16M20 4L4 20" stroke-linecap="round" />
      </svg>
    </a>
  {%- endif -%}
  {%- if settings.youtube_url != blank -%}
    <a href="{{ settings.youtube_url }}" aria-label="YouTube" target="_blank" rel="noopener">
      <svg width="{{ size }}" height="{{ size }}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <rect x="2" y="5" width="20" height="14" rx="4" />
        <path d="M10 9l5 3-5 3V9Z" fill="currentColor" stroke="none" />
      </svg>
    </a>
  {%- endif -%}
</div>
