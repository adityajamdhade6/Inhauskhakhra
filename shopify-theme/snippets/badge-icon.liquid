{%- comment -%}
  Usage: {% render 'badge-icon', name: 'veg', size: 28, color: '#191108' %}
  Shapes: veg, baked, no-palm-oil, small-batch, fssai (falls back to a checkmark).
{%- endcomment -%}
{%- assign name = name | default: '' | downcase -%}
{%- assign size = size | default: 32 -%}
{%- assign color = color | default: '#191108' -%}

<svg viewBox="0 0 32 32" width="{{ size }}" height="{{ size }}" role="presentation" aria-hidden="true">
  <g fill="none" stroke="{{ color }}" stroke-width="2" stroke-linejoin="round" stroke-linecap="round">
    {%- case name -%}
      {%- when 'veg' -%}
        <rect x="4" y="4" width="24" height="24" rx="3" />
        <circle cx="16" cy="16" r="6" fill="{{ color }}" stroke="none" />
      {%- when 'baked' -%}
        <path d="M16 5c4 5 6 8 6 11a6 6 0 1 1-12 0c0-1.6.6-3 1.6-4.6C12.4 13 13 14 14 14c0-3 .8-5.6 2-9Z" />
      {%- when 'no-palm-oil' -%}
        <path d="M16 5c4.5 5 7 9.4 7 13a7 7 0 1 1-14 0c0-3.6 2.5-8 7-13Z" />
        <path d="M7 7l18 18" />
      {%- when 'small-batch' -%}
        <path d="M13 4h6v5l4 15a2 2 0 0 1-2 2.5H11A2 2 0 0 1 9 24l4-15V4Z" />
        <path d="M11 15h10" />
      {%- when 'fssai' -%}
        <path d="M16 4 27 8v8c0 8-5 12.4-11 16C10 28.4 5 24 5 16V8Z" />
        <path d="M11.5 16l3 3 6-6" />
      {%- else -%}
        <circle cx="16" cy="16" r="12" />
        <path d="M11 16l4 4 7-8" />
    {%- endcase -%}
  </g>
</svg>
