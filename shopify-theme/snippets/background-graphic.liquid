{%- comment -%}
  Renders a full-bleed, tone-on-tone decorative background graphic.
  Usage: {% render 'background-graphic', variant: 'sunburst', color: '#191108', opacity: 0.12 %}
  Variants: sunburst | waves | rays | stripes | blob
{%- endcomment -%}
{%- assign variant = variant | default: 'sunburst' -%}
{%- assign color = color | default: 'currentColor' -%}
{%- assign opacity = opacity | default: 0.12 -%}

<div style="position:absolute;inset:0;overflow:hidden;pointer-events:none;color:{{ color }};opacity:{{ opacity }};" aria-hidden="true">
  {%- if variant == 'sunburst' -%}
    <svg viewBox="0 0 100 100" preserveAspectRatio="xMidYMid slice" style="width:100%;height:100%;">
      <g stroke="currentColor" fill="none">
        <line x1="50" y1="50" x2="120.00" y2="50.00" stroke-width="0.6" />
        <line x1="50" y1="50" x2="118.24" y2="65.58" stroke-width="0.6" />
        <line x1="50" y1="50" x2="113.07" y2="80.37" stroke-width="0.6" />
        <line x1="50" y1="50" x2="104.73" y2="93.64" stroke-width="0.6" />
        <line x1="50" y1="50" x2="93.64" y2="104.73" stroke-width="0.6" />
        <line x1="50" y1="50" x2="80.37" y2="113.07" stroke-width="0.6" />
        <line x1="50" y1="50" x2="65.58" y2="118.24" stroke-width="0.6" />
        <line x1="50" y1="50" x2="50.00" y2="120.00" stroke-width="0.6" />
        <line x1="50" y1="50" x2="34.42" y2="118.24" stroke-width="0.6" />
        <line x1="50" y1="50" x2="19.63" y2="113.07" stroke-width="0.6" />
        <line x1="50" y1="50" x2="6.36" y2="104.73" stroke-width="0.6" />
        <line x1="50" y1="50" x2="-4.73" y2="93.64" stroke-width="0.6" />
        <line x1="50" y1="50" x2="-13.07" y2="80.37" stroke-width="0.6" />
        <line x1="50" y1="50" x2="-18.24" y2="65.58" stroke-width="0.6" />
        <line x1="50" y1="50" x2="-20.00" y2="50.00" stroke-width="0.6" />
        <line x1="50" y1="50" x2="-18.24" y2="34.42" stroke-width="0.6" />
        <line x1="50" y1="50" x2="-13.07" y2="19.63" stroke-width="0.6" />
        <line x1="50" y1="50" x2="-4.73" y2="6.36" stroke-width="0.6" />
        <line x1="50" y1="50" x2="6.36" y2="-4.73" stroke-width="0.6" />
        <line x1="50" y1="50" x2="19.63" y2="-13.07" stroke-width="0.6" />
        <line x1="50" y1="50" x2="34.42" y2="-18.24" stroke-width="0.6" />
        <line x1="50" y1="50" x2="50.00" y2="-20.00" stroke-width="0.6" />
        <line x1="50" y1="50" x2="65.58" y2="-18.24" stroke-width="0.6" />
        <line x1="50" y1="50" x2="80.37" y2="-13.07" stroke-width="0.6" />
        <line x1="50" y1="50" x2="93.64" y2="-4.73" stroke-width="0.6" />
        <line x1="50" y1="50" x2="104.73" y2="6.36" stroke-width="0.6" />
        <line x1="50" y1="50" x2="113.07" y2="19.63" stroke-width="0.6" />
        <line x1="50" y1="50" x2="118.24" y2="34.42" stroke-width="0.6" />
      </g>
    </svg>
  {%- elsif variant == 'waves' -%}
    <svg viewBox="0 0 200 100" preserveAspectRatio="none" style="width:100%;height:100%;">
      <g stroke="currentColor" fill="none" stroke-width="1">
        <path d="M -10 12 Q 15 2, 40 12 T 90 12 T 140 12 T 190 12 T 240 12" />
        <path d="M -10 30 Q 15 20, 40 30 T 90 30 T 140 30 T 190 30 T 240 30" />
        <path d="M -10 48 Q 15 38, 40 48 T 90 48 T 140 48 T 190 48 T 240 48" />
        <path d="M -10 66 Q 15 56, 40 66 T 90 66 T 140 66 T 190 66 T 240 66" />
        <path d="M -10 84 Q 15 74, 40 84 T 90 84 T 140 84 T 190 84 T 240 84" />
      </g>
    </svg>
  {%- elsif variant == 'rays' -%}
    <svg viewBox="0 0 100 100" preserveAspectRatio="xMidYMid slice" style="width:100%;height:100%;">
      <g stroke="currentColor" fill="none" stroke-width="0.6">
        <circle cx="80" cy="20" r="8" />
        <circle cx="80" cy="20" r="18" />
        <circle cx="80" cy="20" r="28" />
        <circle cx="80" cy="20" r="38" />
        <circle cx="80" cy="20" r="48" />
        <circle cx="80" cy="20" r="58" />
        <circle cx="80" cy="20" r="68" />
      </g>
    </svg>
  {%- elsif variant == 'stripes' -%}
    <svg viewBox="0 0 200 120" preserveAspectRatio="none" style="width:100%;height:100%;">
      <g stroke="currentColor" fill="none" stroke-width="6">
        <path d="M -60 130 Q -20 60, -40 -10" />
        <path d="M -36 130 Q 4 60, -16 -10" />
        <path d="M -12 130 Q 28 60, 8 -10" />
        <path d="M 12 130 Q 52 60, 32 -10" />
        <path d="M 36 130 Q 76 60, 56 -10" />
        <path d="M 60 130 Q 100 60, 80 -10" />
        <path d="M 84 130 Q 124 60, 104 -10" />
        <path d="M 108 130 Q 148 60, 128 -10" />
        <path d="M 132 130 Q 172 60, 152 -10" />
        <path d="M 156 130 Q 196 60, 176 -10" />
      </g>
    </svg>
  {%- elsif variant == 'blob' -%}
    <svg viewBox="0 0 100 100" preserveAspectRatio="xMidYMid slice" style="width:100%;height:100%;">
      <g fill="currentColor">
        <path d="M76 8C92 18 98 42 90 62C82 82 58 96 36 90C14 84 -2 60 4 38C10 16 32 2 52 2C58 2 66 4 76 8Z" />
      </g>
    </svg>
  {%- endif -%}
</div>
