<section style="background:var(--color-cream);padding:160px 0 80px;min-height:100vh;">
  <div class="ihk-container">
    <h1 class="ihk-display" style="color:var(--color-ink);font-size:clamp(36px, 6vw, 64px);">COLLECTIONS</h1>
    <div style="margin-top:48px;display:grid;grid-template-columns:repeat(auto-fill, minmax(240px, 1fr));gap:32px;">
      {%- for collection in collections -%}
        <a href="{{ collection.url }}" style="display:block;text-align:center;">
          {%- if collection.featured_image -%}
            <img src="{{ collection.featured_image | image_url: width: 500 }}" alt="{{ collection.title }}" style="width:100%;height:auto;">
          {%- endif -%}
          <p style="margin-top:16px;font-weight:700;color:var(--color-ink);">{{ collection.title }}</p>
        </a>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{ "name": "List collections", "settings": [] }
{% endschema %}
