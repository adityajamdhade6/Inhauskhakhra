{%- assign p = product -%}
<section style="background:var(--color-cream);padding:160px 0 80px;min-height:100vh;">
  <div class="ihk-container" style="display:grid;grid-template-columns:1fr;gap:48px;">
    <div style="display:flex;justify-content:center;">
      <img
        src="{{ p.featured_image | image_url: width: 800 }}"
        alt="{{ p.featured_image.alt | default: p.title }}"
        width="420"
        style="width:100%;max-width:420px;height:auto;filter:drop-shadow(10px 14px 18px rgba(25,17,8,0.3));"
      >
    </div>

    <div>
      <h1 class="ihk-display" style="color:var(--color-ink);font-size:clamp(36px, 5vw, 64px);">{{ p.title }}</h1>
      <p style="margin-top:16px;font-size:22px;font-weight:700;color:var(--color-ink);">
        {{ p.selected_or_first_available_variant.price | money }}
      </p>

      {%- if p.description != blank -%}
        <div style="margin-top:24px;max-width:520px;font-size:16px;font-weight:500;color:var(--color-ink-soft);line-height:1.6;">
          {{ p.description }}
        </div>
      {%- endif -%}

      <form data-ihk-cart-form action="{{ routes.cart_add_url }}" method="post" enctype="multipart/form-data" style="margin-top:32px;">
        {%- if p.variants.size > 1 -%}
          <select name="id" style="padding:12px 16px;border:2px solid var(--color-ink);border-radius:8px;font-family:var(--font-body);font-size:14px;margin-bottom:16px;">
            {%- for variant in p.variants -%}
              <option value="{{ variant.id }}" {% if variant == p.selected_or_first_available_variant %}selected{% endif %} {% unless variant.available %}disabled{% endunless %}>
                {{ variant.title }}{% unless variant.available %} — Sold out{% endunless %}
              </option>
            {%- endfor -%}
          </select>
        {%- else -%}
          <input type="hidden" name="id" value="{{ p.selected_or_first_available_variant.id }}">
        {%- endif -%}

        <div>
          <button type="submit" class="ihk-btn ihk-btn--ink" {% unless p.available %}disabled{% endunless %}>
            {% if p.available %}Add to Cart{% else %}Sold Out{% endif %}
          </button>
        </div>
      </form>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Product",
  "settings": []
}
{% endschema %}
