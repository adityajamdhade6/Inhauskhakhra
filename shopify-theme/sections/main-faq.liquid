<section style="background:var(--color-cream);padding:160px 0 80px;min-height:100vh;">
  <div class="ihk-container" style="max-width:760px;">
    <h1 class="ihk-display" style="color:var(--color-ink);font-size:clamp(36px, 6vw, 72px);">
      {{ section.settings.heading | default: 'FAQ.' }}
    </h1>

    <div class="ihk-accordion" style="margin-top:48px;">
      {%- for block in section.blocks -%}
        {%- if block.type == 'faq_item' -%}
          <details>
            <summary style="font-size:20px;">{{ block.settings.question }}</summary>
            <div class="ihk-accordion-body">{{ block.settings.answer }}</div>
          </details>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "FAQ",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "FAQ." }
  ],
  "blocks": [
    {
      "type": "faq_item",
      "name": "Question",
      "settings": [
        { "type": "text", "id": "question", "label": "Question" },
        { "type": "richtext", "id": "answer", "label": "Answer" }
      ]
    }
  ]
}
{% endschema %}
