<section style="background:var(--color-cream);padding:160px 0 80px;min-height:100vh;">
  <div class="ihk-container">
    <h1 class="ihk-display" style="color:var(--color-ink);font-size:clamp(36px, 6vw, 64px);">{{ blog.title }}</h1>
    <div style="margin-top:48px;display:flex;flex-direction:column;gap:32px;max-width:680px;">
      {%- for article in blog.articles -%}
        <a href="{{ article.url }}">
          <p style="font-family:var(--font-display);font-size:28px;color:var(--color-ink);">{{ article.title }}</p>
          <p style="margin-top:8px;color:var(--color-ink-soft);">{{ article.published_at | date: '%B %d, %Y' }}</p>
        </a>
      {%- else -%}
        <p style="color:var(--color-ink-soft);">No posts yet.</p>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{ "name": "Blog", "settings": [] }
{% endschema %}
