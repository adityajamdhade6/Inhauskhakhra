<section style="background:var(--color-cream);padding:160px 0 80px;min-height:100vh;">
  <div class="ihk-container" style="max-width:720px;">
    <h1 class="ihk-display" style="color:var(--color-ink);font-size:clamp(32px, 5vw, 56px);">{{ article.title }}</h1>
    <p style="margin-top:8px;color:var(--color-ink-soft);">{{ article.published_at | date: '%B %d, %Y' }}</p>
    <div style="margin-top:32px;font-size:16px;color:var(--color-ink-soft);line-height:1.7;">
      {{ article.content }}
    </div>
  </div>
</section>

{% schema %}
{ "name": "Article", "settings": [] }
{% endschema %}
