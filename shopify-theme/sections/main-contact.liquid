<section style="background:var(--color-cream);padding:160px 0 80px;min-height:100vh;">
  <div class="ihk-container">
    <h1 class="ihk-display" style="color:var(--color-ink);font-size:clamp(40px, 7vw, 80px);">
      {{ section.settings.heading | default: 'GET IN TOUCH.' }}
    </h1>
    {%- if section.settings.subheading != blank -%}
      <p style="margin-top:16px;max-width:480px;font-size:18px;font-weight:500;color:var(--color-ink-soft);">
        {{ section.settings.subheading }}
      </p>
    {%- endif -%}

    <div style="margin-top:56px;display:grid;grid-template-columns:1fr;gap:56px;">
      <div style="max-width:520px;">
        {%- form 'contact', id: 'ContactForm' -%}
          {%- if form.posted_successfully? -%}
            <p style="padding:16px;border:2px solid var(--color-methi);border-radius:8px;color:var(--color-methi-dark);font-weight:700;margin-bottom:24px;">
              Thanks — we've got your message and will get back to you soon.
            </p>
          {%- endif -%}
          {%- if form.errors -%}
            <div style="padding:16px;border:2px solid var(--color-schezwan);border-radius:8px;margin-bottom:24px;">
              {%- for field in form.errors -%}
                <p style="color:var(--color-schezwan);font-weight:700;margin:0;">
                  {%- if field == 'form' -%}
                    {{ form.errors.messages[field] }}
                  {%- else -%}
                    {{ form.errors.translated_fields[field] | capitalize }} {{ form.errors.messages[field] }}
                  {%- endif -%}
                </p>
              {%- endfor -%}
            </div>
          {%- endif -%}

          <div style="display:flex;flex-direction:column;gap:20px;">
            <div>
              <label for="ContactFormName" style="display:block;font-size:12px;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:var(--color-ink);margin-bottom:8px;">Name</label>
              <input
                type="text"
                id="ContactFormName"
                name="contact[name]"
                value="{{ form.name }}"
                autocomplete="name"
                style="width:100%;padding:14px 16px;border:2px solid var(--color-ink);border-radius:8px;font-family:var(--font-body);font-size:15px;"
              >
            </div>
            <div>
              <label for="ContactFormEmail" style="display:block;font-size:12px;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:var(--color-ink);margin-bottom:8px;">Email *</label>
              <input
                type="email"
                id="ContactFormEmail"
                name="contact[email]"
                value="{{ form.email }}"
                autocomplete="email"
                required
                style="width:100%;padding:14px 16px;border:2px solid var(--color-ink);border-radius:8px;font-family:var(--font-body);font-size:15px;"
              >
            </div>
            <div>
              <label for="ContactFormPhone" style="display:block;font-size:12px;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:var(--color-ink);margin-bottom:8px;">Phone (optional)</label>
              <input
                type="tel"
                id="ContactFormPhone"
                name="contact[phone]"
                value="{{ form.phone }}"
                autocomplete="tel"
                style="width:100%;padding:14px 16px;border:2px solid var(--color-ink);border-radius:8px;font-family:var(--font-body);font-size:15px;"
              >
            </div>
            <div>
              <label for="ContactFormMessage" style="display:block;font-size:12px;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:var(--color-ink);margin-bottom:8px;">Message *</label>
              <textarea
                id="ContactFormMessage"
                name="contact[body]"
                rows="6"
                required
                style="width:100%;padding:14px 16px;border:2px solid var(--color-ink);border-radius:8px;font-family:var(--font-body);font-size:15px;resize:vertical;"
              >{{ form.body }}</textarea>
            </div>
            <button type="submit" class="ihk-btn ihk-btn--ink" style="width:fit-content;">Send Message</button>
          </div>
        {%- endform -%}
      </div>

      <div>
        <p style="font-size:12px;font-weight:700;letter-spacing:0.3em;color:rgba(25,17,8,0.5);text-transform:uppercase;">Reach Us Directly</p>
        <div style="margin-top:16px;display:flex;flex-direction:column;gap:12px;font-size:16px;font-weight:500;color:var(--color-ink);">
          {%- if settings.contact_email != blank -%}
            <a href="mailto:{{ settings.contact_email }}">{{ settings.contact_email }}</a>
          {%- endif -%}
          {%- if settings.contact_phone != blank -%}
            <a href="tel:{{ settings.contact_phone | replace: ' ', '' }}">{{ settings.contact_phone }}</a>
          {%- endif -%}
        </div>
        <div style="margin-top:24px;">
          {% render 'social-icons', color: 'var(--color-ink)', size: 22 %}
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Contact",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "GET IN TOUCH." },
    { "type": "textarea", "id": "subheading", "label": "Subheading" }
  ]
}
{% endschema %}
