<section style="background:var(--color-cream);padding:48px 0;">
  <div class="ihk-container" style="display:flex;flex-wrap:wrap;justify-content:center;gap:16px;">
    {%- for block in section.blocks -%}
      {%- if block.type == 'badge' -%}
        <div class="ihk-sticker ihk-wiggle-hover" style="display:flex;align-items:center;gap:10px;padding:10px 20px;background:var(--color-cream);" {{ block.shopify_attributes }}>
          {% render 'badge-icon', name: block.settings.icon, size: 24, color: 'var(--color-ink)' %}
          <span style="font-size:13px;font-weight:800;letter-spacing:0.02em;text-transform:uppercase;color:var(--color-ink);">{{ block.settings.label }}</span>
        </div>
      {%- endif -%}
    {%- endfor -%}
  </div>
</section>

{% schema %}
{
  "name": "Trust badges",
  "settings": [],
  "blocks": [
    {
      "type": "badge",
      "name": "Badge",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "veg", "label": "Vegetarian" },
            { "value": "baked", "label": "Baked / Flame" },
            { "value": "no-palm-oil", "label": "No Palm Oil" },
            { "value": "small-batch", "label": "Small Batch" },
            { "value": "fssai", "label": "Shield / Certified" },
            { "value": "check", "label": "Checkmark" }
          ],
          "default": "check"
        },
        { "type": "text", "id": "label", "label": "Label" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Trust badges",
      "blocks": [
        { "type": "badge", "settings": { "icon": "veg", "label": "100% Vegetarian" } },
        { "type": "badge", "settings": { "icon": "baked", "label": "Baked, Not Fried" } },
        { "type": "badge", "settings": { "icon": "no-palm-oil", "label": "No Palm Oil" } }
      ]
    }
  ]
}
{% endschema %}
