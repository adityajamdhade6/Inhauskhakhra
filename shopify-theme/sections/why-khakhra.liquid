<section id="why" style="position:relative;background:var(--color-cream);padding:96px 0;">
  <div class="ihk-container">
    <div class="ihk-reveal">
      <span class="ihk-eyebrow" style="color:rgba(25,17,8,0.7);">{{ section.settings.eyebrow | default: 'Why Coin Khakhra' }}</span>
    </div>
    <div class="ihk-reveal">
      <h2 class="ihk-display" style="margin-top:24px;max-width:900px;color:var(--color-ink);font-size:clamp(36px, 5.5vw, 72px);">
        {{ section.settings.headline | default: 'MORE CRUNCH.<br>LESS BORING.' }}
      </h2>
    </div>

    <div style="margin-top:64px;padding-top:40px;border-top:2px solid rgba(25,17,8,0.15);display:grid;grid-template-columns:repeat(auto-fit, minmax(280px, 1fr));gap:48px;">
      {%- for block in section.blocks -%}
        {%- if block.type == 'feature' -%}
          <div class="ihk-reveal" style="display:flex;gap:24px;">
            <span class="ihk-display" style="font-size:28px;color:rgba(25,17,8,0.3);">{% if forloop.index < 10 %}0{% endif %}{{ forloop.index }}</span>
            <div>
              <h3 class="ihk-display" style="font-size:26px;color:var(--color-ink);">{{ block.settings.title }}</h3>
              <p style="margin-top:12px;max-width:340px;font-size:16px;font-weight:500;color:var(--color-ink-soft);">{{ block.settings.body }}</p>
            </div>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Why Khakhra",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Why Coin Khakhra" },
    { "type": "text", "id": "headline", "label": "Headline (use <br> for line break)", "default": "MORE CRUNCH.<br>LESS BORING." }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature",
      "settings": [
        { "type": "text", "id": "title", "label": "Title" },
        { "type": "textarea", "id": "body", "label": "Body" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Why Khakhra",
      "blocks": [
        { "type": "feature", "settings": { "title": "BAKED. NOT FRIED.", "body": "Stone-baked till it snaps — not soaked in oil till it sags." } },
        { "type": "feature", "settings": { "title": "100% ROUND. ZERO SHORTCUTS.", "body": "Every coin khakhra pressed thin and even for a crunch that carries through." } },
        { "type": "feature", "settings": { "title": "5 FLAVOURS. ONE OBSESSION.", "body": "From Jeera-humble to Schezwan-loud, made for repeat offenders." } },
        { "type": "feature", "settings": { "title": "NO PALM OIL. NO NONSENSE.", "body": "Ingredients you can actually pronounce, in a language you already speak." } }
      ]
    }
  ]
}
{% endschema %}
