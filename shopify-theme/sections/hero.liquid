{%- assign hero_product = section.settings.bundle_product -%}
{%- if hero_product == blank and section.settings.fallback_handle != blank -%}
  {%- assign hero_product = all_products[section.settings.fallback_handle] -%}
{%- endif -%}

<section id="top" style="position:relative;background:var(--color-cream);padding:140px 0 64px;">
  <div class="ihk-container" style="display:grid;grid-template-columns:1fr;gap:40px;align-items:center;">

    <div class="ihk-reveal" style="order:2;">
      <h1 class="ihk-display" style="color:var(--color-ink);font-size:clamp(38px, 6vw, 76px);max-width:680px;">
        {{ section.settings.headline | default: 'A Snack That Skips The Guilt Trip.' }}
      </h1>
      <p style="margin-top:20px;max-width:520px;font-size:19px;font-weight:500;color:var(--color-ink-soft);line-height:1.5;">
        {{ section.settings.subhead | default: 'Thin, crispy, stone-baked coin khakhra in five bold flavours. Never fried. Never boring.' }}
      </p>

      {%- if section.settings.show_rating -%}
        <div style="margin-top:20px;display:flex;align-items:center;gap:10px;flex-wrap:wrap;">
          <span class="ihk-stars" aria-hidden="true">
            {%- for i in (1..5) -%}
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 3l2.6 5.6 6 .7-4.4 4.2 1.1 6-5.3-3-5.3 3 1.1-6L3.4 9.3l6-.7L12 3Z" /></svg>
            {%- endfor -%}
          </span>
          {%- if section.settings.rating_caption != blank -%}
            <span style="font-size:14px;font-weight:700;color:var(--color-ink);">{{ section.settings.rating_caption }}</span>
          {%- endif -%}
        </div>
      {%- endif -%}

      <div data-sticky-trigger style="margin-top:28px;">
        <a href="{{ hero_product.url | default: section.settings.cta_link | default: routes.all_products_collection_url }}" class="ihk-btn ihk-btn--ink ihk-btn--lg">
          {{ section.settings.cta_label | default: 'Shop Now' }}
        </a>
      </div>

      <div style="margin-top:32px;display:flex;flex-wrap:wrap;gap:10px;">
        {%- for block in section.blocks -%}
          {%- if block.type == 'badge' -%}
            <span style="display:inline-flex;align-items:center;gap:6px;padding:8px 14px;border-radius:999px;border:1px solid rgba(25,17,8,0.15);font-size:12px;font-weight:700;letter-spacing:0.02em;text-transform:uppercase;color:var(--color-ink-soft);">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="var(--color-methi)" stroke-width="3"><path d="M4 12l5 5L20 6" stroke-linecap="round" stroke-linejoin="round" /></svg>
              {{ block.settings.label }}
            </span>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>

    <div class="ihk-reveal" style="order:1;display:flex;justify-content:center;">
      {%- if hero_product != blank -%}
        <img
          src="{{ hero_product.featured_image | image_url: width: 900 }}"
          alt="{{ hero_product.title }}"
          width="440"
          style="width:100%;max-width:440px;height:auto;filter:drop-shadow(0 30px 40px rgba(25,17,8,0.18));"
        >
      {%- endif -%}
    </div>
  </div>
</section>

{% render 'sticky-cta-bar', product: hero_product %}

<style>
  @media (min-width: 900px) {
    #top .ihk-container {
      grid-template-columns: 1.05fr 0.95fr;
      gap: 64px;
    }
    #top .ihk-reveal {
      order: initial !important;
    }
  }
</style>

{% schema %}
{
  "name": "Hero",
  "settings": [
    { "type": "text", "id": "headline", "label": "Headline", "default": "A Snack That Skips The Guilt Trip." },
    { "type": "textarea", "id": "subhead", "label": "Subheading" },
    { "type": "checkbox", "id": "show_rating", "label": "Show star rating row", "default": false, "info": "Only enable once you have a real aggregate rating to show — don't fabricate one." },
    { "type": "text", "id": "rating_caption", "label": "Rating caption", "info": "e.g. '4.8 from 300+ reviews' — must be a real figure." },
    { "type": "text", "id": "cta_label", "label": "Button label", "default": "Shop Now" },
    { "type": "product", "id": "bundle_product", "label": "Hero product (your best seller or bundle)" },
    {
      "type": "text",
      "id": "fallback_handle",
      "label": "Product handle (used only if the product picker above is empty)"
    },
    { "type": "url", "id": "cta_link", "label": "Button link (used if no product is set)" }
  ],
  "blocks": [
    {
      "type": "badge",
      "name": "Trust badge",
      "settings": [{ "type": "text", "id": "label", "label": "Label" }]
    }
  ],
  "presets": [
    {
      "name": "Hero",
      "blocks": [
        { "type": "badge", "settings": { "label": "No Palm Oil" } },
        { "type": "badge", "settings": { "label": "Baked, Not Fried" } },
        { "type": "badge", "settings": { "label": "100% Vegetarian" } },
        { "type": "badge", "settings": { "label": "Made In India" } }
      ]
    }
  ]
}
{% endschema %}
