<section style="background:var(--color-cream);padding:160px 0 80px;min-height:100vh;">
  <div class="ihk-container">
    <h1 class="ihk-display" style="color:var(--color-ink);font-size:clamp(36px, 6vw, 72px);">YOUR CART</h1>

    {%- if cart.item_count == 0 -%}
      <p style="margin-top:24px;font-size:18px;color:var(--color-ink-soft);">Your cart is empty.</p>
      <a href="{{ routes.root_url }}" class="ihk-btn ihk-btn--ink" style="margin-top:24px;display:inline-flex;">Continue Shopping</a>
    {%- else -%}
      <form action="{{ routes.cart_url }}" method="post" novalidate>
        <div style="margin-top:40px;display:flex;flex-direction:column;gap:24px;">
          {%- for item in cart.items -%}
            <div style="display:flex;align-items:center;gap:20px;padding-bottom:24px;border-bottom:1px solid rgba(25,17,8,0.15);">
              <img src="{{ item.image | image_url: width: 160 }}" alt="{{ item.title }}" width="80" style="width:80px;height:auto;">
              <div style="flex:1;">
                <p style="font-weight:700;color:var(--color-ink);margin:0;">{{ item.product.title }}</p>
                {%- if item.variant.title != 'Default Title' -%}
                  <p style="font-size:14px;color:var(--color-ink-soft);margin:4px 0 0;">{{ item.variant.title }}</p>
                {%- endif -%}
                <p style="font-size:14px;color:var(--color-ink-soft);margin:4px 0 0;">{{ item.original_price | money }}</p>
              </div>
              <input
                type="number"
                name="updates[{{ item.key }}]"
                value="{{ item.quantity }}"
                min="0"
                style="width:64px;padding:8px;border:2px solid var(--color-ink);border-radius:8px;font-family:var(--font-body);"
              >
              <p style="font-weight:700;color:var(--color-ink);min-width:80px;text-align:right;">{{ item.final_line_price | money }}</p>
            </div>
          {%- endfor -%}
        </div>

        <div style="margin-top:32px;display:flex;flex-direction:column;align-items:flex-end;gap:16px;">
          <p style="font-size:20px;font-weight:700;color:var(--color-ink);">Subtotal: {{ cart.total_price | money }}</p>
          <div style="display:flex;gap:12px;">
            <button type="submit" name="update" class="ihk-btn ihk-btn--outline-ink">Update Cart</button>
            <button type="submit" name="checkout" class="ihk-btn ihk-btn--ink">Checkout</button>
          </div>
        </div>
      </form>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Cart",
  "settings": []
}
{% endschema %}
