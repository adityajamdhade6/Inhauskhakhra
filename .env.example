# Shopify cart permalinks — leave unset and "Shop" buttons fall back to
# on-page anchor links. Fill these in once your products exist in Shopify.
#
# Store domain, e.g. inhaus-khakhra.myshopify.com
NEXT_PUBLIC_SHOPIFY_STORE_DOMAIN=

# Numeric variant ID for each flavour's product (Shopify admin → Product →
# Variant → the number in the URL, or via the Storefront API).
NEXT_PUBLIC_SHOPIFY_VARIANT_MAGIC_MASALA=
NEXT_PUBLIC_SHOPIFY_VARIANT_PANI_PURI=
NEXT_PUBLIC_SHOPIFY_VARIANT_JEERA=
NEXT_PUBLIC_SHOPIFY_VARIANT_METHI=
NEXT_PUBLIC_SHOPIFY_VARIANT_SCHEZWAN=
